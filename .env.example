# RBC Studio public browser configuration. The anonymous key is safe only with correct RLS.
RBC_REMOTE_FACTORY=false
RBC_SUPABASE_URL=
RBC_SUPABASE_ANON_KEY=

# GPU worker. Never expose the service-role key to browser JavaScript.
RBC_SUPABASE_SERVICE_ROLE_KEY=
RBC_WORKER_ID=
RBC_WORKER_QUEUES=noop
RBC_MODEL_CACHE_DIR=
RBC_STORAGE_BUCKET_ORIGINALS=
RBC_STORAGE_BUCKET_DERIVATIVES=
RBC_LOG_LEVEL=INFO
RBC_SENTRY_DSN=

# n8n is not started in Milestone 0. Values are placeholders for a later gated deployment.
N8N_ENCRYPTION_KEY=
N8N_HOST=
N8N_PROTOCOL=https
DB_TYPE=postgresdb
DB_POSTGRESDB_HOST=
DB_POSTGRESDB_DATABASE=
DB_POSTGRESDB_USER=
DB_POSTGRESDB_PASSWORD=

# Official platform application credentials. No adapter is enabled in Milestone 0.
RBC_META_CLIENT_ID=
RBC_META_CLIENT_SECRET=
RBC_PINTEREST_CLIENT_ID=
RBC_PINTEREST_CLIENT_SECRET=
RBC_TIKTOK_CLIENT_KEY=
RBC_TIKTOK_CLIENT_SECRET=
RBC_X_CLIENT_ID=
RBC_X_CLIENT_SECRET=
RBC_GOOGLE_CLIENT_ID=
RBC_GOOGLE_CLIENT_SECRET=
