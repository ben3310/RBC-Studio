{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://rarebagclub.local/contracts/cutout-qa.v1.schema.json",
  "title": "RBC cutout QA explanation bundle",
  "type": "object",
  "required": ["schema_version", "asset_id", "model_id", "model_revision", "score", "decision", "signals", "created_at"],
  "properties": {
    "schema_version": {"const": 1},
    "asset_id": {"type": "string", "minLength": 1},
    "model_id": {"type": "string", "minLength": 1},
    "model_revision": {"type": "string", "minLength": 1},
    "score": {"type": "number", "minimum": 0, "maximum": 1},
    "decision": {"enum": ["accept", "fallback", "manual_review", "reject"]},
    "signals": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "value", "passed"],
        "properties": {"name": {"type": "string", "minLength": 1}, "value": {"type": "number"}, "passed": {"type": "boolean"}, "note": {"type": "string"}},
        "additionalProperties": false
      }
    },
    "created_at": {"type": "string", "format": "date-time"}
  },
  "additionalProperties": false
}
