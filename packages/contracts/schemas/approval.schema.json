{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://rarebagclub.local/contracts/approval.v1.schema.json",
  "title": "RBC fingerprint-bound approval",
  "type": "object",
  "required": ["schema_version", "id", "content_item_id", "decision", "binary_fingerprint", "copy_fingerprint", "reviewer_id", "created_at"],
  "properties": {
    "schema_version": {"const": 1},
    "id": {"type": "string", "minLength": 1},
    "content_item_id": {"type": "string", "minLength": 1},
    "decision": {"enum": ["approved", "rejected", "changes_requested"]},
    "binary_fingerprint": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
    "copy_fingerprint": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
    "reviewer_id": {"type": "string", "minLength": 1},
    "note": {"type": "string"},
    "created_at": {"type": "string", "format": "date-time"}
  },
  "additionalProperties": false
}
