{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://rarebagclub.local/contracts/source-asset.v1.schema.json",
  "title": "RBC immutable source or derivative asset",
  "type": "object",
  "required": ["schema_version", "id", "piece_id", "kind", "storage_key", "sha256", "mime_type", "width", "height", "bytes", "rights_class"],
  "properties": {
    "schema_version": {"const": 1},
    "id": {"type": "string", "minLength": 1},
    "piece_id": {"type": "string", "minLength": 1},
    "campaign_id": {"type": ["string", "null"]},
    "kind": {"enum": ["product_original", "product_detail", "owned_mood", "licensed_mood", "generated_mood", "persona", "cutout", "mask", "preview", "render"]},
    "storage_key": {"type": "string", "minLength": 1},
    "sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
    "mime_type": {"type": "string", "pattern": "^[a-z0-9.+-]+/[a-z0-9.+-]+$"},
    "width": {"type": "integer", "minimum": 1},
    "height": {"type": "integer", "minimum": 1},
    "bytes": {"type": "integer", "minimum": 1},
    "parent_asset_id": {"type": ["string", "null"]},
    "rights_class": {"enum": ["owned", "licensed", "generated"]},
    "derivation": {"type": "object"}
  },
  "additionalProperties": false
}
